{
  "name": "proof-vc-workspace",
  "version": "0.3.0",
  "private": true,
  "license": "Apache-2.0",
  "author": "Jeremie Charrier <jeremie.charrier@proof.com>",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "check-all": "yarn format && yarn lint && yarn build && yarn publint",
    "clean": "tsc -b --clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "publint": "yarn workspaces foreach --all --no-private run publint",
    "test": "yarn workspaces foreach --all --no-private run test"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "eslint": "^10.5.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
